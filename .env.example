# Copy to .env and fill in. All values are OPTIONAL — the tool runs without them
# using deterministic heuristics. A key unlocks Claude-driven reasoning.

# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Override the model (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Max tokens per LLM call (default: 1024)
ANTHROPIC_MAX_TOKENS=1024
